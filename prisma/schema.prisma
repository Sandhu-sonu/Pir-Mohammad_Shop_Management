datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

enum Role {
  OWNER
  MANAGER
  STAFF
  VIEW_ONLY
  SUPER_ADMIN
}

enum BusinessType {
  GENERAL_STORE
  GROCERY
  HARDWARE
  ELECTRICAL
  PAINT
  MOBILE
  COMPUTER
  STATIONERY
  BOOK_STORE
  GARMENTS
  FOOTWEAR
  COSMETICS
  DAIRY
  BAKERY
  SWEET_SHOP
  SPORTS
  FURNITURE
  ELECTRONICS
  AUTO_PARTS
  PESTICIDE
  SEED
  FERTILIZER
  BUILDING_MATERIAL
  WHOLESALE
  MEDICAL
}

enum UserStatus {
  ACTIVE
  LOCKED
  DISABLED
}

enum TransactionType {
  PURCHASE
  SALE
  RETURN
  DAMAGE
  ADJUSTMENT
  OPENING
}

enum CustomerLedgerType {
  OPENING
  SALE
  PAYMENT
  ADJUSTMENT
  REVERSAL
}

enum SupplierLedgerType {
  OPENING
  PURCHASE
  PAYMENT
  ADJUSTMENT
  RETURN
  REVERSAL
}

enum PaymentMethod {
  CASH
  UPI
  BANK_TRANSFER
  CARD
  CREDIT
}

enum PurchaseStatus {
  DRAFT
  RECEIVED
  PARTIAL
  COMPLETED
  CANCELLED
}

enum SaleStatus {
  DRAFT
  COMPLETED
  REVERSED
}

enum StockAlertStatus {
  ACTIVE
  DISMISSED
  RESOLVED
}

model User {
  id                   String                 @id @default(uuid())
  mobile               String                 @unique
  name                 String
  password             String
  role                 Role                   @default(STAFF)
  pin                  String? // Hashed PIN
  status               UserStatus             @default(ACTIVE)
  mustChangePin        Boolean                @default(true)
  adminRole            AdminRole?
  mobileVerified       Boolean                @default(false)
  emailVerified        Boolean                @default(false)
  failedAttempts       Int                    @default(0)
  lockedUntil          DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  shopId               String
  shop                 Shop                   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  auditLogs            AuditLog[]
  barcodeScanSessions  BarcodeScanSession[]
  supportTickets       SupportTicket[]        @relation("CreatedTickets")
  assignedTickets      SupportTicket[]        @relation("AssignedTickets")
  ticketMessages       SupportTicketMessage[]
  changedSubscriptions SubscriptionHistory[]  @relation("SubscriptionModifier")

  // Relations
  createdSales      Sale[]          @relation("CreatedByUser")
  closedSales       Sale[]          @relation("ClosedByUser")
  reversedSales     Sale[]          @relation("ReversedByUser")
  expenses          Expense[]       @relation("ExpenseCreatedByUser")
  reversedExpenses  Expense[]       @relation("ExpenseReversedByUser")
  dailyClosings     DailyClosing[]  @relation("DailyClosingClosedByUser")
  staffClosings     DailyClosing[]  @relation("DailyClosingStaff")
  ownerClosings     DailyClosing[]  @relation("DailyClosingOwner")
  reversedClosings  DailyClosing[]  @relation("DailyClosingReversedByUser")
  purchases         Purchase[]
  backupsCreated    BackupHistory[] @relation("BackupCreatedByUser")
  restoresPerformed RestoreLog[]    @relation("RestorePerformedByUser")
  exportsCreated           ExportHistory[]           @relation("ExportCreatedByUser")
  subscriptionTransactions SubscriptionTransaction[]
  approvedRefunds          Refund[]

  @@index([shopId])
}

model Shop {
  id                  String                @id @default(uuid())
  name                String
  address             String?
  gst                 String?
  phone               String?
  email               String?
  footerMessage       String?
  returnPolicy        String?
  logo                String?
  currency            String                @default("INR")
  businessType        BusinessType          @default(GENERAL_STORE)
  gstRegistered       Boolean               @default(false)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  isSuspended         Boolean               @default(false)
  deletedAt           DateTime?
  users               User[]
  products            Product[]
  customers           Customer[]
  suppliers           Supplier[]
  settings            Settings?
  sales               Sale[]
  purchases           Purchase[]
  expenses            Expense[]
  dailyClosings       DailyClosing[]
  categories          Category[]
  brands              Brand[]
  productImports      ProductImport[]
  barcodeScanSessions BarcodeScanSession[]
  backups             BackupHistory[]
  restores            RestoreLog[]
  exports             ExportHistory[]
  subscription        Subscription?
  subscriptionHistory SubscriptionHistory[]
  supportTickets      SupportTicket[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  saasInvoices             SaaSInvoice[]
  saasPayments             SaaSPayment[]
  subscriptionTransactions SubscriptionTransaction[]

  @@map("shops")
}

enum ReceiptFormat {
  SIMPLE
  DETAILED
}

enum PrinterType {
  THERMAL_58
  THERMAL_80
  A4
}

enum DiscountType {
  FIXED
  PERCENT
}

model Settings {
  id                    String        @id @default(uuid())
  shopId                String        @unique
  shop                  Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  language              String        @default("pa") // "en" or "pa"
  theme                 String        @default("light") // "light" or "dark"
  lowStockAlert         Boolean       @default(true)
  receiptFormat         ReceiptFormat @default(SIMPLE)
  printerType           PrinterType   @default(THERMAL_80)
  receiptPrefix         String        @default("RCP-")
  taxPrefix             String        @default("INV-")
  currencySymbol        String        @default("₹")
  decimalPrecision      Int           @default(2)
  dateFormat            String        @default("DD/MM/YYYY") // "DD/MM/YYYY" or "DD-MM-YYYY"
  allowItemDiscount     Boolean       @default(true)
  allowBillDiscount     Boolean       @default(true)
  maxStaffDiscount      Decimal       @default(10.00) @db.Decimal(5, 2)
  requireDiscountReason Boolean       @default(false)
  reasonPercentLimit    Decimal       @default(15.00) @db.Decimal(5, 2)
  reasonAmountLimit     Decimal       @default(500.00) @db.Decimal(10, 2)
  autoSuggestPunjabi    Boolean       @default(true)
  autoSuggestEnglish    Boolean       @default(true)
  minPasswordLength        Int           @default(6)
  requirePasswordUppercase Boolean       @default(false)
  requirePasswordNumber    Boolean       @default(false)
  requirePasswordSpecial   Boolean       @default(false)

  @@map("settings")
}

model Category {
  id       String    @id @default(uuid())
  name     String
  shopId   String
  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([shopId, name])
  @@map("categories")
}

model Brand {
  id       String    @id @default(uuid())
  name     String
  shopId   String
  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([shopId, name])
  @@map("brands")
}

model Product {
  id               String                 @id @default(uuid())
  sku              String?
  barcode          String?
  nameEn           String
  namePa           String
  categoryName     String?                @map("category") // Backward compatible mapping
  categoryId       String?
  category         Category?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brandId          String?
  brand            Brand?                 @relation(fields: [brandId], references: [id], onDelete: SetNull)
  purchasePrice    Decimal                @db.Decimal(10, 2)
  sellingPrice     Decimal                @db.Decimal(10, 2)
  currentQuantity  Decimal                @default(0) @db.Decimal(10, 2)
  unit             String                 @default("PCS") // PCS, KG, LTR, BOX, etc.
  minStock         Decimal                @default(5) @db.Decimal(10, 2) // Backward compatible naming
  reorderLevel     Decimal                @default(5) @db.Decimal(10, 2)
  taxRate          Decimal                @default(0) @db.Decimal(5, 2)
  isActive         Boolean                @default(true)
  isAutoTranslated Boolean                @default(false)
  supplierId       String?
  supplier         Supplier?              @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  shopId           String
  shop             Shop                   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  isDeleted        Boolean                @default(false)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  transactions     InventoryTransaction[]
  saleItems        SaleItem[]
  purchaseItems    PurchaseItem[]
  purchaseReturns  PurchaseReturn[]
  stockAlerts      StockAlert[]

  // Optional fields for configuration engine (Phase 9)
  manufacturer      String?
  modelNumber       String?
  batchNumber       String?
  expiryDate        DateTime?
  manufacturingDate DateTime?
  warrantyMonths    Int?
  serialNumber      String?
  imei              String?
  color             String?
  size              String?
  variant           String?
  hsnCode           String?
  gstRate           Decimal?  @db.Decimal(5, 2)

  @@unique([shopId, barcode])
  @@unique([shopId, sku])
  @@index([shopId])
  @@index([categoryId])
  @@index([brandId])
  @@index([barcode])
  @@index([supplierId])
  @@map("products")
}

model InventoryTransaction {
  id          String          @id @default(uuid())
  productId   String
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  type        TransactionType
  quantity    Decimal         @db.Decimal(10, 2)
  previousQty Decimal         @db.Decimal(10, 2)
  newQty      Decimal         @db.Decimal(10, 2)
  price       Decimal         @default(0) @db.Decimal(10, 2)
  referenceId String?
  note        String?
  createdAt   DateTime        @default(now())
  userId      String?

  @@index([productId])
  @@index([createdAt])
  @@map("inventory_transactions")
}

model Customer {
  id             String           @id @default(uuid())
  name           String
  mobile         String?
  address        String?
  notes          String?
  openingBalance Decimal          @default(0) @db.Decimal(10, 2)
  currentBalance Decimal          @default(0) @db.Decimal(10, 2)
  shopId         String
  shop           Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  isDeleted      Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  sales          Sale[]
  payments       Payment[]
  ledgers        CustomerLedger[]

  @@unique([shopId, mobile])
  @@index([shopId])
  @@map("customers")
}

model CustomerLedger {
  id           String             @id @default(uuid())
  customerId   String
  customer     Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type         CustomerLedgerType
  amount       Decimal            @db.Decimal(10, 2)
  balanceAfter Decimal            @db.Decimal(10, 2)
  referenceId  String?
  note         String?
  createdAt    DateTime           @default(now())
  saleId       String?
  sale         Sale?              @relation(fields: [saleId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([createdAt])
  @@map("customer_ledgers")
}

model Sale {
  id               String           @id @default(uuid())
  invoiceNumber    String           @unique
  date             DateTime         @default(now())
  customerId       String?
  customer         Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  shopId           String
  shop             Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  subTotal         Decimal          @db.Decimal(10, 2)
  discount         Decimal          @default(0) @db.Decimal(10, 2)
  billDiscount     Decimal          @default(0) @db.Decimal(10, 2)
  billDiscountType DiscountType     @default(FIXED)
  discountReason   String?
  total            Decimal          @db.Decimal(10, 2)
  paymentMethod    PaymentMethod    @default(CASH)
  paidAmount       Decimal          @db.Decimal(10, 2)
  dueAmount        Decimal          @db.Decimal(10, 2)
  status           SaleStatus       @default(COMPLETED)
  isReversed       Boolean          @default(false)
  createdAt        DateTime         @default(now())
  items            SaleItem[]
  payments         Payment[]
  ledgers          CustomerLedger[]

  // Ownership tracking
  createdByUserId  String?
  createdByUser    User?   @relation("CreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  closedByUserId   String?
  closedByUser     User?   @relation("ClosedByUser", fields: [closedByUserId], references: [id], onDelete: SetNull)
  reversedByUserId String?
  reversedByUser   User?   @relation("ReversedByUser", fields: [reversedByUserId], references: [id], onDelete: SetNull)

  @@index([shopId])
  @@index([date])
  @@index([customerId])
  @@index([createdByUserId])
  @@index([closedByUserId])
  @@index([reversedByUserId])
  @@map("sales")
}

model SaleItem {
  id             String       @id @default(uuid())
  saleId         String
  sale           Sale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId      String
  product        Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity       Decimal      @db.Decimal(10, 2)
  purchasePrice  Decimal      @db.Decimal(10, 2)
  sellingPrice   Decimal      @db.Decimal(10, 2)
  originalPrice  Decimal      @default(0) @db.Decimal(10, 2)
  itemDiscount   Decimal      @default(0) @db.Decimal(10, 2)
  discountType   DiscountType @default(FIXED)
  discountReason String?
  total          Decimal      @db.Decimal(10, 2)

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model Payment {
  id            String        @id @default(uuid())
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  saleId        String?
  sale          Sale?         @relation(fields: [saleId], references: [id], onDelete: SetNull)
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod @default(CASH)
  note          String?
  createdAt     DateTime      @default(now())

  @@index([customerId])
  @@map("payments")
}

model Supplier {
  id             String           @id @default(uuid())
  name           String
  mobile         String?
  gst            String?
  shopId         String
  shop           Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  isDeleted      Boolean          @default(false)
  currentBalance Decimal          @default(0) @db.Decimal(10, 2)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  products       Product[]
  purchases      Purchase[]
  ledgers        SupplierLedger[]

  @@index([shopId])
  @@map("suppliers")
}

model SupplierLedger {
  id            String             @id @default(uuid())
  supplierId    String
  supplier      Supplier           @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  type          SupplierLedgerType
  amount        Decimal            @db.Decimal(10, 2)
  balanceAfter  Decimal            @db.Decimal(10, 2)
  paymentMethod PaymentMethod      @default(CASH)
  referenceId   String?
  note          String?
  createdAt     DateTime           @default(now())

  @@index([supplierId])
  @@index([createdAt])
  @@map("supplier_ledgers")
}

model Purchase {
  id              String           @id @default(uuid())
  invoiceNumber   String?
  date            DateTime         @default(now())
  supplierId      String
  supplier        Supplier         @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  shopId          String
  shop            Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  total           Decimal          @db.Decimal(10, 2)
  paymentMethod   PaymentMethod    @default(CASH)
  paidAmount      Decimal          @db.Decimal(10, 2)
  dueAmount       Decimal          @db.Decimal(10, 2)
  status          PurchaseStatus   @default(COMPLETED)
  note            String?
  userId          String?
  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt       DateTime         @default(now())
  items           PurchaseItem[]
  purchaseReturns PurchaseReturn[]

  @@index([shopId])
  @@index([supplierId])
  @@map("purchases")
}

model PurchaseItem {
  id            String   @id @default(uuid())
  purchaseId    String
  purchase      Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity      Decimal  @db.Decimal(10, 2)
  purchasePrice Decimal  @db.Decimal(10, 2)

  @@index([purchaseId])
  @@index([productId])
  @@map("purchase_items")
}

model PurchaseReturn {
  id            String   @id @default(uuid())
  purchaseId    String
  purchase      Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity      Decimal  @db.Decimal(10, 2)
  purchasePrice Decimal  @db.Decimal(10, 2)
  reason        String?
  createdAt     DateTime @default(now())

  @@index([purchaseId])
  @@index([productId])
  @@map("purchase_returns")
}

model ProductImport {
  id                     String               @id @default(uuid())
  shopId                 String
  shop                   Shop                 @relation(fields: [shopId], references: [id], onDelete: Cascade)
  filename               String
  importedCount          Int                  @default(0)
  updatedCount           Int                  @default(0)
  failedCount            Int                  @default(0)
  createdCategoriesCount Int                  @default(0)
  createdBrandsCount     Int                  @default(0)
  status                 String               @default("COMPLETED")
  createdAt              DateTime             @default(now())
  errors                 ProductImportError[]

  @@index([shopId])
  @@map("product_imports")
}

model ProductImportError {
  id       String        @id @default(uuid())
  importId String
  import   ProductImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  rowNum   Int
  sku      String?
  errorMsg String
  rawData  String?
  date     DateTime      @default(now())

  @@index([importId])
  @@map("product_import_errors")
}

model StockAlert {
  id          String           @id @default(uuid())
  productId   String
  product     Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  status      StockAlertStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  isDismissed Boolean          @default(false)

  @@index([productId])
  @@map("stock_alerts")
}

model BarcodeScanSession {
  id        String       @id @default(uuid())
  shopId    String
  shop      Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  logs      BarcodeLog[]

  @@index([shopId])
  @@index([userId])
  @@map("barcode_scan_sessions")
}

model BarcodeLog {
  id        String             @id @default(uuid())
  barcode   String
  sessionId String
  session   BarcodeScanSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  scannedAt DateTime           @default(now())

  @@index([barcode])
  @@index([sessionId])
  @@map("barcode_logs")
}

model Expense {
  id               String        @id @default(uuid())
  category         String // Predefined or custom category
  amount           Decimal       @db.Decimal(10, 2)
  date             DateTime      @default(now())
  description      String?
  paymentMethod    PaymentMethod @default(CASH)
  notes            String?
  isReversed       Boolean       @default(false)
  reversalReason   String?
  reversedByUserId String?
  reversedByUser   User?         @relation("ExpenseReversedByUser", fields: [reversedByUserId], references: [id], onDelete: SetNull)
  userId           String? // Created By
  user             User?         @relation("ExpenseCreatedByUser", fields: [userId], references: [id], onDelete: SetNull)
  shopId           String
  shop             Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([shopId])
  @@index([date])
  @@map("expenses")
}

model DailyClosing {
  id                   String   @id @default(uuid())
  date                 DateTime @default(now())
  openingCash          Decimal  @db.Decimal(10, 2)
  salesCash            Decimal  @default(0) @db.Decimal(10, 2)
  salesUpi             Decimal  @default(0) @db.Decimal(10, 2)
  expensesCash         Decimal  @default(0) @db.Decimal(10, 2)
  paymentsReceivedCash Decimal  @default(0) @db.Decimal(10, 2)
  paymentsReceivedUpi  Decimal  @default(0) @db.Decimal(10, 2)
  supplierPaymentsCash Decimal  @default(0) @db.Decimal(10, 2)
  supplierPaymentsUpi  Decimal  @default(0) @db.Decimal(10, 2)
  closingCash          Decimal  @db.Decimal(10, 2)
  difference           Decimal  @db.Decimal(10, 2)
  notes                String?
  isLocked             Boolean  @default(false)
  staffSignature       String?
  staffUserId          String?
  staffUser            User?    @relation("DailyClosingStaff", fields: [staffUserId], references: [id], onDelete: SetNull)
  ownerSignature       String?
  ownerUserId          String?
  ownerUser            User?    @relation("DailyClosingOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  withdrawals          Decimal  @default(0) @db.Decimal(10, 2)
  userId               String? // Closed By
  user                 User?    @relation("DailyClosingClosedByUser", fields: [userId], references: [id], onDelete: SetNull)
  isReversed           Boolean  @default(false)
  reversalReason       String?
  reversedByUserId     String?
  reversedByUser       User?    @relation("DailyClosingReversedByUser", fields: [reversedByUserId], references: [id], onDelete: SetNull)
  shopId               String
  shop                 Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())

  @@unique([shopId, date])
  @@index([shopId])
  @@map("daily_closings")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  shopId    String?
  shop      Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  action    String
  details   String?
  device    String?
  ip        String?
  module    String   @default("General")
  entity    String?
  before    String?  @db.Text
  after     String?  @db.Text
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([shopId])
  @@map("audit_logs")
}

model BackupHistory {
  id            String   @id @default(uuid())
  shopId        String
  shop          Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  backupType    String // 'COMPLETE', 'PRODUCTS', etc.
  backupVersion String // e.g. '1.0'
  schemaVersion String // e.g. '1.0'
  appVersion    String // e.g. '1.0.0'
  filename      String
  fileSize      Int
  status        String // 'SUCCESS', 'FAILED'
  duration      Int // duration in milliseconds
  createdById   String?
  createdBy     User?    @relation("BackupCreatedByUser", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())

  @@index([shopId])
  @@map("backup_history")
}

model RestoreLog {
  id              String   @id @default(uuid())
  shopId          String
  shop            Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  backupHistoryId String?
  status          String // 'SUCCESS', 'FAILED'
  error           String?
  restoredById    String?
  restoredBy      User?    @relation("RestorePerformedByUser", fields: [restoredById], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())

  @@index([shopId])
  @@map("restore_logs")
}

model ExportHistory {
  id          String   @id @default(uuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  module      String // 'PRODUCTS', 'CUSTOMERS', etc.
  format      String // 'CSV', 'EXCEL', 'JSON'
  filename    String
  fileSize    Int?
  status      String // 'PENDING', 'SUCCESS', 'FAILED'
  progress    Int      @default(0)
  createdById String?
  createdBy   User?    @relation("ExportCreatedByUser", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([shopId])
  @@map("export_history")
}

enum AdminRole {
  SUPER_ADMIN
  SUPPORT
  BILLING
  SALES
  READ_ONLY
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum BillingPeriod {
  MONTHLY
  YEARLY
  LIFETIME
}

model Plan {
  id                  String                @id @default(uuid())
  name                String                @unique
  price               Decimal               @db.Decimal(10, 2)
  billingPeriod       BillingPeriod         @default(MONTHLY)
  isActive            Boolean               @default(true)
  deletedAt           DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  features            PlanFeature[]
  subscriptions       Subscription[]
  subscriptionHistory SubscriptionHistory[]
  subscriptionTransactions SubscriptionTransaction[]
  saasInvoices SaaSInvoice[]

  @@map("plans")
}

model Feature {
  id          String        @id @default(uuid())
  code        String        @unique // e.g. "MOBILE_APP", "ADVANCED_REPORTS"
  name        String
  description String?
  deletedAt   DateTime?
  planLinks   PlanFeature[]

  @@map("features")
}

model PlanFeature {
  id         String  @id @default(uuid())
  planId     String
  plan       Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  featureId  String
  feature    Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)
  enabled    Boolean @default(false)
  limitType  String // "PRODUCTS", "USERS", "BRANCHES", "API_CALLS", "BACKUPS"
  limitValue Int     @default(0)

  @@unique([planId, featureId])
  @@map("plan_features")
}

model Subscription {
  id          String             @id @default(uuid())
  shopId      String             @unique
  shop        Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  planId      String
  plan        Plan               @relation(fields: [planId], references: [id])
  saasInvoices SaaSInvoice[]
  status      SubscriptionStatus @default(TRIAL)
  startDate   DateTime           @default(now())
  endDate     DateTime
  trialEndsAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@map("subscriptions")
}

model SubscriptionHistory {
  id              String             @id @default(uuid())
  shopId          String
  shop            Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  planId          String
  plan            Plan               @relation(fields: [planId], references: [id])
  status          SubscriptionStatus
  startDate       DateTime
  endDate         DateTime
  changedByUserId String?
  changedByUser   User?              @relation("SubscriptionModifier", fields: [changedByUserId], references: [id])
  reason          String? // "Trial expired", "Manual upgrade", "Payment received", etc.
  changedAt       DateTime           @default(now())

  @@map("subscription_history")
}

model SupportTicket {
  id               String                 @id @default(uuid())
  shopId           String
  shop             Shop                   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  userId           String
  user             User                   @relation("CreatedTickets", fields: [userId], references: [id], onDelete: Cascade)
  title            String
  status           SupportTicketStatus    @default(OPEN)
  priority         TicketPriority         @default(LOW)
  assignedToUserId String?
  assignedTo       User?                  @relation("AssignedTickets", fields: [assignedToUserId], references: [id])
  deletedAt        DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  messages         SupportTicketMessage[]

  @@map("support_tickets")
}

model SupportTicketMessage {
  id        String        @id @default(uuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String        @db.Text
  createdAt DateTime      @default(now())

  @@map("support_ticket_messages")
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  message   String   @db.Text
  published Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("announcements")
}

model AppVersion {
  id                   String   @id @default(uuid())
  version              String   @unique
  minimumMobileVersion String
  forceUpdate          Boolean  @default(false)
  releaseNotes         String?  @db.Text
  createdAt            DateTime @default(now())

  @@map("app_versions")
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

model Notification {
  id        String             @id @default(uuid())
  shopId    String
  shop      Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  title     String
  message   String             @db.Text
  type      String
  status    NotificationStatus @default(UNREAD)
  readAt    DateTime?
  createdAt DateTime           @default(now())

  @@map("notifications")
}

enum SaaSInvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum SaasPaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum SubscriptionTransactionType {
  UPGRADE
  DOWNGRADE
  RENEWAL
  TRIAL_EXTENSION
  CANCELLATION
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
  FAILED
}

model SaaSInvoice {
  id               String             @id @default(uuid())
  invoiceNumber    String             @unique // e.g., INV-2026-000001
  shopId           String
  shop             Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  subscriptionId   String?
  subscription     Subscription?      @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  planId           String
  plan             Plan               @relation(fields: [planId], references: [id])
  issueDate        DateTime           @default(now())
  dueDate          DateTime
  subtotal         Decimal            @db.Decimal(10, 2)
  taxAmount        Decimal            @default(0) @db.Decimal(10, 2)
  discountAmount   Decimal            @default(0) @db.Decimal(10, 2)
  totalAmount      Decimal            @db.Decimal(10, 2)
  currency         String             @default("INR")
  status           SaaSInvoiceStatus  @default(PENDING)
  pdfUrl           String?
  notes            String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  payments         SaaSPayment[]
  paymentAttempts  SaaSPaymentAttempt[]
  transactions     SubscriptionTransaction[]
  refunds          Refund[]

  @@index([shopId])
  @@index([subscriptionId])
  @@map("saas_invoices")
}

model SaaSPayment {
  id               String            @id @default(uuid())
  invoiceId        String
  invoice          SaaSInvoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  shopId           String
  shop             Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  paymentDate      DateTime          @default(now())
  amount           Decimal           @db.Decimal(10, 2)
  paymentMethod    String            // e.g., CARD, UPI, BANK_TRANSFER
  gateway          String            // e.g., STRIPE, RAZORPAY, MANUAL
  gatewayReference String?           // ID returned by payment gateway
  transactionId    String?           @unique
  status           SaasPaymentStatus @default(SUCCESS)
  remarks          String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  refunds          Refund[]

  @@index([invoiceId])
  @@index([shopId])
  @@map("saas_payments")
}

model SaaSPaymentAttempt {
  id               String        @id @default(uuid())
  invoiceId        String
  invoice          SaaSInvoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  gateway          String
  requestPayload   String?       @db.Text
  responsePayload  String?       @db.Text
  responseCode     String?
  status           String        // e.g., SUCCESS, FAILED
  createdAt        DateTime      @default(now())

  @@index([invoiceId])
  @@map("saas_payment_attempts")
}

model SubscriptionTransaction {
  id               String                      @id @default(uuid())
  shopId           String
  shop             Shop                        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  invoiceId        String?
  invoice          SaaSInvoice?                @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  type             SubscriptionTransactionType
  planId           String
  plan             Plan                        @relation(fields: [planId], references: [id])
  startDate        DateTime
  endDate          DateTime
  amount           Decimal                     @db.Decimal(10, 2)
  changedByUserId  String?
  changedByUser    User?                       @relation(fields: [changedByUserId], references: [id])
  notes            String?
  createdAt        DateTime                    @default(now())

  @@index([shopId])
  @@index([invoiceId])
  @@map("saas_subscription_transactions")
}

model Refund {
  id               String       @id @default(uuid())
  paymentId        String
  payment          SaaSPayment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoiceId        String
  invoice          SaaSInvoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  refundAmount     Decimal      @db.Decimal(10, 2)
  refundReason     String?
  approvedByUserId String?
  approvedByUser   User?        @relation(fields: [approvedByUserId], references: [id])
  gatewayReference String?
  status           RefundStatus @default(PENDING)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([paymentId])
  @@index([invoiceId])
  @@map("saas_refunds")
}

model PaymentGatewayLog {
  id               String   @id @default(uuid())
  gateway          String
  eventType        String?
  payload          String   @db.Text
  ip               String?
  createdAt        DateTime @default(now())

  @@map("payment_gateway_logs")
}

